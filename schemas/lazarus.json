{
  "title": "lazarus power cycle system",
  "description": "main configuration",
  "properties": {
    "lazarus": {
      "type": "object",
      "description": "parent object",
      "properties": {
        "loop_interval": {
          "type": "number",
          "description": "time to sleep in between loop iterations",
          "minimum": 1,
          "maximum": 120
        },
        "ingest_file": {
          "type": "string",
          "description": "location of ingest file",
          "pattern": "^/tmp/[a-z0-9]+.csv$"
        },
        "elastic_interval": {
          "type": "number",
          "description": "upload metrics to elastic every n seconds",
          "minimum": 5,
          "maximum": 20
        },
        "job_execute_delta": {
          "type": "number",
          "description": "execute jobs at trigger time + execute delta",
          "minimum": 5,
          "maximum": 60
        },
        "power": {
          "type": "object",
          "description": "define power event thresholds",
          "properties": {
            "trigger": {
              "type": "object",
              "description": "power trigger object",
              "properties": {
                "status": {
                  "type": "number",
                  "description": "seconds where status is 'ONBATT'",
                  "minimum": 240,
                  "maximum": 480
                },
                "event": {
                  "type": "number",
                  "description": "total seconds to evaluate trigger event",
                  "minimum": 300,
                  "maximum": 600
                }
              },
              "required": [
                "status",
                "event"
              ]
            },
            "clear": {
              "type": "object",
              "description": "power clear object",
              "properties": {
                "status": {
                  "type": "number",
                  "description": "seconds where status is 'ONLINE'",
                  "minimum": 480,
                  "maximum": 2880
                },
                "event": {
                  "type": "number",
                  "description": "total seconds to evaluate clear event",
                  "minimum": 600,
                  "maximum": 3600
                }
              },
              "required": [
                "status",
                "event"
              ]
            }
          },
          "required": [
            "trigger",
            "clear"
          ]
        },
        "logging": {
          "type": "object",
          "description": "configure project logging",
          "properties": {
            "format": {
              "type": "object",
              "description": "log formatting timestamp",
              "properties": {
                "banner": {
                  "type": "string",
                  "description": "banner format for logs"
                },
                "date": {
                  "type": "string",
                  "description": "log formatting timestamp date element",
                  "pattern": "^%Y(-|_|:)%m(-|_|:)%d$"
                },
                "time": {
                  "type": "string",
                  "description": "log formatting timestamp time element",
                  "pattern": "^%H(-|_|:)%M(-|_|:)%S$"
                }
              },
              "required": [
                "banner",
                "date",
                "time"
              ]
            }
          },
          "required": ["format"]
        }
      },
      "required": [
        "loop_interval",
        "ingest_file",
        "elastic_interval",
        "job_execute_delta",
        "power",
        "logging"
      ]
    }
  }
}
